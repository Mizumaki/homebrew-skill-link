#!/usr/bin/env bash
# skill-link — manage Claude Code skill symlinks
#
# Usage:
#   skill-link init      Create an empty skill-link.conf template (no-op if
#                        the file already exists)
#   skill-link sync      Create symlinks for skills in configured dirs and
#                        remove stale symlinks that no longer match the conf
#   skill-link list      Show all skills and their link status
#   skill-link clean     Remove broken symlinks from the skills directory
#
# Configuration:
#   <claude-dir>/skill-link.conf — INI-style sections, # = comment.
#   Two sections:
#     [dirs]    Each line points to a parent directory; every direct
#               subdirectory is linked as a skill.
#     [skills]  Each line points to a single skill directory containing
#               SKILL.md.
#
#   Within either section, two line forms are accepted:
#     <path>                   plain entry; symlink name = basename(path)
#     <prefix> = <path>        prefixed entry; symlink name = "<prefix>:<basename>"
#
#   If the file does not exist, an error is raised.
#
#   The Claude config directory defaults to ~/.claude but can be overridden
#   via the CLAUDE_CONFIG_DIR environment variable (matching Claude Code).

set -euo pipefail

VERSION="1.2.0"

CLAUDE_DIR="${CLAUDE_CONFIG_DIR:-$HOME/.claude}"
SKILLS_DIR="$CLAUDE_DIR/skills"
CONF_FILE="$CLAUDE_DIR/skill-link.conf"
LEGACY_CONF_FILE="$CLAUDE_DIR/skill-dirs.conf"

usage() {
  cat <<EOF
Usage: skill-link <command>

Commands:
  init      Create skill-link.conf from a template (only if it does not exist)
  sync      Create symlinks for skills in configured dirs and remove stale
            symlinks (those whose source dir is no longer in conf)
  list      Show all skills and their link status
  clean     Remove broken symlinks

Options:
  --version Show version and exit
  -h, --help Show this help and exit

Configuration:
  $CONF_FILE — INI-style sections (# = comment). Required.
    [dirs]                parent dirs; every subdirectory is linked
    <prefix> = <path>     prefix the resulting symlink as "<prefix>:<name>"
    [skills]              single-skill dirs (must contain SKILL.md)
EOF
}

check_conf() {
  if [[ ! -f "$CONF_FILE" ]]; then
    if [[ -f "$LEGACY_CONF_FILE" ]]; then
      echo "Error: $CONF_FILE not found." >&2
      echo "A legacy $LEGACY_CONF_FILE was detected. The format has changed:" >&2
      echo "run 'skill-link init' to create a fresh skill-link.conf and" >&2
      echo "migrate your entries by hand into [dirs] / [skills] sections." >&2
      exit 1
    fi
    echo "Error: $CONF_FILE not found." >&2
    echo "Run 'skill-link init' to create it from a template." >&2
    exit 1
  fi
  # Run the parser once up-front so syntax errors surface before any side
  # effects. Subsequent callers use process substitution which would
  # otherwise swallow the parser's non-zero exit.
  get_entries >/dev/null
}

# Emit one record per entry as
#   <type>\t<expanded-path>\t<prefix>
# where <type> is `parent` (from [dirs]) or `skill` (from [skills]), and
# <prefix> is empty for plain entries.
get_entries() {
  local lineno=0 section="" line stripped key value path prefix
  while IFS= read -r line || [[ -n "$line" ]]; do
    lineno=$((lineno + 1))
    stripped="${line#"${line%%[![:space:]]*}"}"   # trim leading whitespace
    stripped="${stripped%"${stripped##*[![:space:]]}"}"   # trim trailing whitespace
    [[ -z "$stripped" ]] && continue
    [[ "$stripped" == \#* ]] && continue

    if [[ "$stripped" =~ ^\[(.*)\]$ ]]; then
      local name="${BASH_REMATCH[1]}"
      case "$name" in
        dirs|skills) section="$name" ;;
        *)
          echo "Error: $CONF_FILE: unknown section [$name] (line $lineno)" >&2
          exit 1
          ;;
      esac
      continue
    fi

    if [[ -z "$section" ]]; then
      echo "Error: $CONF_FILE: entry before any [dirs]/[skills] section (line $lineno)" >&2
      exit 1
    fi

    prefix=""
    if [[ "$stripped" == *"="* ]]; then
      key="${stripped%%=*}"
      value="${stripped#*=}"
      key="${key%"${key##*[![:space:]]}"}"
      key="${key#"${key%%[![:space:]]*}"}"
      value="${value#"${value%%[![:space:]]*}"}"
      value="${value%"${value##*[![:space:]]}"}"
      if [[ -z "$key" ]]; then
        echo "Error: $CONF_FILE: empty prefix before '=' (line $lineno)" >&2
        exit 1
      fi
      if [[ ! "$key" =~ ^[A-Za-z0-9_-]+$ ]]; then
        echo "Error: $CONF_FILE: invalid prefix '$key' (line $lineno)" >&2
        exit 1
      fi
      if [[ -z "$value" ]]; then
        echo "Error: $CONF_FILE: missing path for prefix '$key' (line $lineno)" >&2
        exit 1
      fi
      prefix="$key"
      path="$value"
    else
      path="$stripped"
    fi

    local type
    case "$section" in
      dirs) type="parent" ;;
      skills) type="skill" ;;
    esac
    printf '%s\t%s\t%s\n' "$type" "$(eval echo "$path")" "$prefix"
  done < "$CONF_FILE"
}

cmd_init() {
  if [[ -e "$CONF_FILE" ]]; then
    echo "$CONF_FILE already exists. Leaving it untouched."
    return
  fi
  mkdir -p "$CLAUDE_DIR"
  cat > "$CONF_FILE" <<'EOF'
# skill-link configuration (https://github.com/Mizumaki/homebrew-skill-link)
#
# [dirs] — each line points to a parent directory; every direct
# subdirectory is linked as a skill under ~/.claude/skills/.
#
# [skills] — each line points to a single skill directory containing
# SKILL.md. The directory itself is linked.
#
# Within either section, write a plain path for an unprefixed entry,
# or "<prefix> = <path>" to namespace the resulting symlink as
# "<prefix>:<name>" — e.g. matt = ~/dev/personal-skills/skills produces
# ~/.claude/skills/matt:<subdir> entries.
#
[dirs]
# ~/Documents/dev/personal-skills/skills
# work = ~/Documents/dev/work-skills/skills

[skills]
# ~/Documents/dev/work/special-skill
# matt = ~/Documents/dev/personal/tdd-skill
EOF
  echo "Created $CONF_FILE"
  echo "Edit it to list your skill directories, then run 'skill-link sync'."
}

# Compose the symlink name for a skill path and optional prefix.
_link_name() {
  local skill_path="$1" prefix="$2"
  local base
  base="$(basename "$skill_path")"
  if [[ -n "$prefix" ]]; then
    printf '%s:%s' "$prefix" "$base"
  else
    printf '%s' "$base"
  fi
}

# Link a single skill dir. Relies on dynamic scope for the caller's
# linked/kept/skipped counters.
_link_one() {
  local skill_path="$1" prefix="${2:-}"
  local link_name target
  link_name="$(_link_name "$skill_path" "$prefix")"
  target="$SKILLS_DIR/$link_name"
  if [[ -L "$target" && -e "$target" ]]; then
    echo "  [keep] $link_name (already linked -> $(readlink "$target"))"
    ((kept++)) || true
  elif [[ -L "$target" && ! -e "$target" ]]; then
    rm "$target"
    ln -s "$skill_path" "$target"
    echo "  [relink] $link_name -> $skill_path (was broken)"
    ((linked++)) || true
  elif [[ -e "$target" ]]; then
    echo "  [skip] $link_name (exists but not a symlink)"
    ((skipped++)) || true
  else
    ln -s "$skill_path" "$target"
    echo "  [link] $link_name -> $skill_path"
    ((linked++)) || true
  fi
}

cmd_install() {
  check_conf
  mkdir -p "$SKILLS_DIR"
  local linked=0 kept=0 skipped=0
  while IFS=$'\t' read -r type path prefix; do
    case "$type" in
      parent)
        if [[ ! -d "$path" ]]; then
          echo "  [warn] $path not found, skipping."
          continue
        fi
        for skill_path in "$path"/*/; do
          [[ -d "$skill_path" ]] || continue
          _link_one "$skill_path" "$prefix"
        done
        ;;
      skill)
        if [[ ! -d "$path" || ! -f "$path/SKILL.md" ]]; then
          echo "  [warn] $path is not a skill (missing dir or no SKILL.md), skipping."
          continue
        fi
        _link_one "${path%/}/" "$prefix"
        ;;
    esac
  done < <(get_entries)
  echo ""
  echo "Done: $linked linked, $kept kept, $skipped skipped."
}

cmd_list() {
  check_conf

  local -a parent_dirs=() parent_prefixes=() skill_paths=() skill_prefixes=()
  while IFS=$'\t' read -r type path prefix; do
    case "$type" in
      parent)
        parent_dirs+=("${path%/}")
        parent_prefixes+=("$prefix")
        ;;
      skill)
        skill_paths+=("${path%/}")
        skill_prefixes+=("$prefix")
        ;;
    esac
  done < <(get_entries)

  echo "Configured directories:"
  local i
  for i in "${!parent_dirs[@]}"; do
    if [[ -n "${parent_prefixes[$i]}" ]]; then
      echo "  ${parent_prefixes[$i]}: ${parent_dirs[$i]}"
    else
      echo "  ${parent_dirs[$i]}"
    fi
  done
  if (( ${#skill_paths[@]} > 0 )); then
    echo ""
    echo "Configured skills:"
    for i in "${!skill_paths[@]}"; do
      if [[ -n "${skill_prefixes[$i]}" ]]; then
        echo "  ${skill_prefixes[$i]}: ${skill_paths[$i]}"
      else
        echo "  ${skill_paths[$i]}"
      fi
    done
  fi
  echo ""
  echo "Skills in $SKILLS_DIR:"

  local found=0
  if [[ -d "$SKILLS_DIR" ]]; then
    for entry in "$SKILLS_DIR"/*; do
      [[ -e "$entry" || -L "$entry" ]] || continue
      local name
      name="$(basename "$entry")"
      if [[ -L "$entry" ]]; then
        local dest
        dest="$(readlink "$entry")"
        if [[ -e "$entry" ]]; then
          echo "  [linked] $name -> $dest"
        else
          echo "  [broken] $name -> $dest (target missing)"
        fi
      else
        echo "  [manual] $name"
      fi
      ((found++)) || true
    done
  fi

  # Parent-entry skills present on disk but not yet linked.
  for i in "${!parent_dirs[@]}"; do
    local conf_dir="${parent_dirs[$i]}" pfx="${parent_prefixes[$i]}"
    [[ -d "$conf_dir" ]] || continue
    for skill_path in "$conf_dir"/*/; do
      [[ -d "$skill_path" ]] || continue
      local link_name target
      link_name="$(_link_name "$skill_path" "$pfx")"
      target="$SKILLS_DIR/$link_name"
      if [[ ! -e "$target" && ! -L "$target" ]]; then
        echo "  [unlinked] $link_name -> ${skill_path%/} (run 'skill-link sync')"
        ((found++)) || true
      fi
    done
  done

  # Single-skill entries that are valid but not yet linked.
  for i in "${!skill_paths[@]}"; do
    local skill_p="${skill_paths[$i]}" pfx="${skill_prefixes[$i]}"
    [[ -d "$skill_p" && -f "$skill_p/SKILL.md" ]] || continue
    local link_name target
    link_name="$(_link_name "$skill_p" "$pfx")"
    target="$SKILLS_DIR/$link_name"
    if [[ ! -e "$target" && ! -L "$target" ]]; then
      echo "  [unlinked] $link_name -> $skill_p (run 'skill-link sync')"
      ((found++)) || true
    fi
  done

  [[ $found -gt 0 ]] || echo "  (none)"
}

cmd_sync() {
  check_conf

  local -a parent_dirs=() skill_paths=()
  while IFS=$'\t' read -r type path _prefix; do
    case "$type" in
      parent) parent_dirs+=("${path%/}") ;;
      skill)  skill_paths+=("${path%/}") ;;
    esac
  done < <(get_entries)

  # Collect symlinks whose source dir is no longer in conf.
  local -a stale=()
  if [[ -d "$SKILLS_DIR" ]]; then
    for entry in "$SKILLS_DIR"/*; do
      [[ -L "$entry" ]] || continue
      local dest dest_clean parent in_conf
      dest="$(readlink "$entry")"
      dest_clean="${dest%/}"
      parent="$(dirname "$dest_clean")"
      in_conf=false
      for conf_dir in "${parent_dirs[@]+"${parent_dirs[@]}"}"; do
        [[ "$parent" == "$conf_dir" ]] && in_conf=true && break
      done
      if [[ "$in_conf" == false ]]; then
        for skill_p in "${skill_paths[@]+"${skill_paths[@]}"}"; do
          [[ "$dest_clean" == "$skill_p" ]] && in_conf=true && break
        done
      fi
      [[ "$in_conf" == false ]] && stale+=("$entry")
    done
  fi

  if [[ ${#stale[@]} -eq 0 ]]; then
    echo "No stale symlinks found."
    echo ""
    cmd_install
    return
  fi

  echo "The following symlinks will be removed:"
  for entry in "${stale[@]}"; do
    echo "  $(basename "$entry") -> $(readlink "$entry")"
  done
  echo ""
  if ! read -r -p "Proceed? [y/N] " answer || [[ ! "$answer" =~ ^[Yy]$ ]]; then
    echo "Aborted."
    exit 0
  fi
  echo ""

  local removed=0
  for entry in "${stale[@]}"; do
    local name
    name="$(basename "$entry")"
    rm "$entry"
    echo "  [removed] $name"
    ((removed++)) || true
  done
  echo "$removed symlink(s) removed."
  echo ""

  cmd_install
}

cmd_clean() {
  if [[ ! -d "$SKILLS_DIR" ]]; then
    echo "No $SKILLS_DIR directory found."
    return
  fi
  local removed=0
  for entry in "$SKILLS_DIR"/*; do
    [[ -L "$entry" ]] || continue
    if [[ ! -e "$entry" ]]; then
      local name
      name="$(basename "$entry")"
      rm "$entry"
      echo "  [removed] $name (broken symlink)"
      ((removed++)) || true
    fi
  done
  echo "Done: $removed broken symlinks removed."
}

case "${1:-}" in
  init)            cmd_init ;;
  sync)            cmd_sync ;;
  list)            cmd_list ;;
  clean)           cmd_clean ;;
  --version)       echo "skill-link $VERSION" ;;
  -h|--help)       usage ;;
  *)               usage; exit 1 ;;
esac

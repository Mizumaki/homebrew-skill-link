#!/usr/bin/env bash
# skill-link — manage Claude Code skill symlinks
#
# Usage:
#   skill-link init      Create an empty skill-dirs.conf template (no-op if
#                        the file already exists)
#   skill-link sync      Create symlinks for skills in configured dirs and
#                        remove stale symlinks that no longer match the conf
#   skill-link list      Show all skills and their link status
#   skill-link clean     Remove broken symlinks from the skills directory
#
# Configuration:
#   <claude-dir>/skill-dirs.conf — one entry per line, # = comment.
#   Two entry forms:
#     <path>            Parent dir; every direct subdirectory is linked.
#     skill: <path>     Single skill; the dir itself is linked. The path
#                       must be a directory containing SKILL.md.
#
#   If the file does not exist, an error is raised.
#
#   The Claude config directory defaults to ~/.claude but can be overridden
#   via the CLAUDE_CONFIG_DIR environment variable (matching Claude Code).

set -euo pipefail

VERSION="1.0.0"

CLAUDE_DIR="${CLAUDE_CONFIG_DIR:-$HOME/.claude}"
SKILLS_DIR="$CLAUDE_DIR/skills"
CONF_FILE="$CLAUDE_DIR/skill-dirs.conf"

usage() {
  cat <<EOF
Usage: skill-link <command>

Commands:
  init      Create skill-dirs.conf from a template (only if it does not exist)
  sync      Create symlinks for skills in configured dirs and remove stale
            symlinks (those whose source dir is no longer in conf)
  list      Show all skills and their link status
  clean     Remove broken symlinks

Options:
  --version Show version and exit
  -h, --help Show this help and exit

Configuration:
  $CONF_FILE — one entry per line (# = comment). Required.
    <path>           parent dir; every subdirectory is linked
    skill: <path>    single skill; the dir itself is linked (must have SKILL.md)
EOF
}

check_conf() {
  if [[ ! -f "$CONF_FILE" ]]; then
    echo "Error: $CONF_FILE not found." >&2
    echo "Run 'skill-link init' to create it from a template." >&2
    exit 1
  fi
}

# Emit one record per non-comment, non-blank conf line as
#   <type>\t<expanded-path>
# where <type> is `parent` or `skill`.
get_entries() {
  while IFS= read -r line || [[ -n "$line" ]]; do
    [[ "$line" =~ ^[[:space:]]*# ]] && continue
    [[ -z "${line//[[:space:]]/}" ]] && continue
    if [[ "$line" =~ ^[[:space:]]*skill:[[:space:]]*(.+)$ ]]; then
      local raw="${BASH_REMATCH[1]}"
      raw="${raw%"${raw##*[![:space:]]}"}"
      printf 'skill\t%s\n' "$(eval echo "$raw")"
    else
      printf 'parent\t%s\n' "$(eval echo "$line")"
    fi
  done < "$CONF_FILE"
}

cmd_init() {
  if [[ -e "$CONF_FILE" ]]; then
    echo "$CONF_FILE already exists. Leaving it untouched."
    return
  fi
  mkdir -p "$CLAUDE_DIR"
  cat > "$CONF_FILE" <<'EOF'
# skill-link configuration (https://github.com/Mizumaki/homebrew-skill-link)
#
# Parent directory — every direct subdirectory is linked as a skill:
# ~/Documents/dev/personal-skills/skills
# ~/Documents/dev/work-skills/skills
#
# Single skill — prefix with "skill:". The path must be a directory
# containing SKILL.md:
# skill: ~/Documents/dev/work/special-skill
EOF
  echo "Created $CONF_FILE"
  echo "Edit it to list your skill directories, then run 'skill-link sync'."
}

# Link a single skill dir. Relies on dynamic scope for the caller's
# linked/kept/skipped counters.
_link_one() {
  local skill_path="$1"
  local skill_name target
  skill_name="$(basename "$skill_path")"
  target="$SKILLS_DIR/$skill_name"
  if [[ -L "$target" && -e "$target" ]]; then
    echo "  [keep] $skill_name (already linked -> $(readlink "$target"))"
    ((kept++)) || true
  elif [[ -L "$target" && ! -e "$target" ]]; then
    rm "$target"
    ln -s "$skill_path" "$target"
    echo "  [relink] $skill_name -> $skill_path (was broken)"
    ((linked++)) || true
  elif [[ -e "$target" ]]; then
    echo "  [skip] $skill_name (exists but not a symlink)"
    ((skipped++)) || true
  else
    ln -s "$skill_path" "$target"
    echo "  [link] $skill_name -> $skill_path"
    ((linked++)) || true
  fi
}

cmd_install() {
  check_conf
  mkdir -p "$SKILLS_DIR"
  local linked=0 kept=0 skipped=0
  while IFS=$'\t' read -r type path; do
    case "$type" in
      parent)
        if [[ ! -d "$path" ]]; then
          echo "  [warn] $path not found, skipping."
          continue
        fi
        for skill_path in "$path"/*/; do
          [[ -d "$skill_path" ]] || continue
          _link_one "$skill_path"
        done
        ;;
      skill)
        if [[ ! -d "$path" || ! -f "$path/SKILL.md" ]]; then
          echo "  [warn] $path is not a skill (missing dir or no SKILL.md), skipping."
          continue
        fi
        _link_one "${path%/}/"
        ;;
    esac
  done < <(get_entries)
  echo ""
  echo "Done: $linked linked, $kept kept, $skipped skipped."
}

cmd_list() {
  check_conf

  local -a parent_dirs=() skill_paths=()
  while IFS=$'\t' read -r type path; do
    case "$type" in
      parent) parent_dirs+=("${path%/}") ;;
      skill)  skill_paths+=("${path%/}") ;;
    esac
  done < <(get_entries)

  echo "Configured directories:"
  for conf_dir in "${parent_dirs[@]+"${parent_dirs[@]}"}"; do
    echo "  $conf_dir"
  done
  if (( ${#skill_paths[@]} > 0 )); then
    echo ""
    echo "Configured skills:"
    for skill_p in "${skill_paths[@]}"; do
      echo "  $skill_p"
    done
  fi
  echo ""
  echo "Skills in $SKILLS_DIR:"

  local found=0
  if [[ -d "$SKILLS_DIR" ]]; then
    for entry in "$SKILLS_DIR"/*; do
      [[ -e "$entry" || -L "$entry" ]] || continue
      local name
      name="$(basename "$entry")"
      if [[ -L "$entry" ]]; then
        local dest
        dest="$(readlink "$entry")"
        if [[ -e "$entry" ]]; then
          echo "  [linked] $name -> $dest"
        else
          echo "  [broken] $name -> $dest (target missing)"
        fi
      else
        echo "  [manual] $name"
      fi
      ((found++)) || true
    done
  fi

  # Parent-entry skills present on disk but not yet linked.
  for conf_dir in "${parent_dirs[@]+"${parent_dirs[@]}"}"; do
    [[ -d "$conf_dir" ]] || continue
    for skill_path in "$conf_dir"/*/; do
      [[ -d "$skill_path" ]] || continue
      local skill_name target
      skill_name="$(basename "$skill_path")"
      target="$SKILLS_DIR/$skill_name"
      if [[ ! -e "$target" && ! -L "$target" ]]; then
        echo "  [unlinked] $skill_name -> ${skill_path%/} (run 'skill-link sync')"
        ((found++)) || true
      fi
    done
  done

  # Single-skill entries that are valid but not yet linked.
  for skill_p in "${skill_paths[@]+"${skill_paths[@]}"}"; do
    [[ -d "$skill_p" && -f "$skill_p/SKILL.md" ]] || continue
    local skill_name target
    skill_name="$(basename "$skill_p")"
    target="$SKILLS_DIR/$skill_name"
    if [[ ! -e "$target" && ! -L "$target" ]]; then
      echo "  [unlinked] $skill_name -> $skill_p (run 'skill-link sync')"
      ((found++)) || true
    fi
  done

  [[ $found -gt 0 ]] || echo "  (none)"
}

cmd_sync() {
  check_conf

  local -a parent_dirs=() skill_paths=()
  while IFS=$'\t' read -r type path; do
    case "$type" in
      parent) parent_dirs+=("${path%/}") ;;
      skill)  skill_paths+=("${path%/}") ;;
    esac
  done < <(get_entries)

  # Collect symlinks whose source dir is no longer in conf.
  local -a stale=()
  if [[ -d "$SKILLS_DIR" ]]; then
    for entry in "$SKILLS_DIR"/*; do
      [[ -L "$entry" ]] || continue
      local dest dest_clean parent in_conf
      dest="$(readlink "$entry")"
      dest_clean="${dest%/}"
      parent="$(dirname "$dest_clean")"
      in_conf=false
      for conf_dir in "${parent_dirs[@]+"${parent_dirs[@]}"}"; do
        [[ "$parent" == "$conf_dir" ]] && in_conf=true && break
      done
      if [[ "$in_conf" == false ]]; then
        for skill_p in "${skill_paths[@]+"${skill_paths[@]}"}"; do
          [[ "$dest_clean" == "$skill_p" ]] && in_conf=true && break
        done
      fi
      [[ "$in_conf" == false ]] && stale+=("$entry")
    done
  fi

  if [[ ${#stale[@]} -eq 0 ]]; then
    echo "No stale symlinks found."
    echo ""
    cmd_install
    return
  fi

  echo "The following symlinks will be removed:"
  for entry in "${stale[@]}"; do
    echo "  $(basename "$entry") -> $(readlink "$entry")"
  done
  echo ""
  if ! read -r -p "Proceed? [y/N] " answer || [[ ! "$answer" =~ ^[Yy]$ ]]; then
    echo "Aborted."
    exit 0
  fi
  echo ""

  local removed=0
  for entry in "${stale[@]}"; do
    local name
    name="$(basename "$entry")"
    rm "$entry"
    echo "  [removed] $name"
    ((removed++)) || true
  done
  echo "$removed symlink(s) removed."
  echo ""

  cmd_install
}

cmd_clean() {
  if [[ ! -d "$SKILLS_DIR" ]]; then
    echo "No $SKILLS_DIR directory found."
    return
  fi
  local removed=0
  for entry in "$SKILLS_DIR"/*; do
    [[ -L "$entry" ]] || continue
    if [[ ! -e "$entry" ]]; then
      local name
      name="$(basename "$entry")"
      rm "$entry"
      echo "  [removed] $name (broken symlink)"
      ((removed++)) || true
    fi
  done
  echo "Done: $removed broken symlinks removed."
}

case "${1:-}" in
  init)            cmd_init ;;
  sync)            cmd_sync ;;
  list)            cmd_list ;;
  clean)           cmd_clean ;;
  --version)       echo "skill-link $VERSION" ;;
  -h|--help)       usage ;;
  *)               usage; exit 1 ;;
esac
